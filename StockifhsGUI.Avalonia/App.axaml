<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StockifhsGUI.Avalonia.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <Application.Resources>
    <Color x:Key="BoardLightColor">#E8D9BF</Color>
    <Color x:Key="BoardDarkColor">#6D4C41</Color>
    <Color x:Key="ChromeColor">#101820</Color>
    <Color x:Key="PanelColor">#182733</Color>
    <Color x:Key="PanelAccentColor">#24414F</Color>

    <SolidColorBrush x:Key="ChromeBrush" Color="{StaticResource ChromeColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelAccentBrush" Color="{StaticResource PanelAccentColor}" />
  </Application.Resources>
</Application>
