<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StockifhsGUI.Avalonia.Views.SettingsWindow"
        Width="520"
        Height="320"
        MinWidth="460"
        MinHeight="280"
        Title="Settings"
        Background="{DynamicResource ChromeBrush}">
  <Grid RowDefinitions="*,Auto" Margin="18">
    <Border Padding="16" CornerRadius="18" Background="{DynamicResource PanelBrush}">
      <Grid RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock FontSize="24" FontWeight="Bold" Text="Model Settings" />
        <TextBlock Grid.Row="1"
                   Margin="0,12,0,0"
                   Foreground="#D7E2EA"
                   TextWrapping="Wrap"
                   Text="Choose how the local advice model should explain analysis positions." />
        <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="10">
          <CheckBox x:Name="FullGpuPowerCheckBox"
                    Content="Use full GPU power for the local model" />
          <TextBlock Foreground="#D7E2EA" Text="Explanation level" />
          <ComboBox x:Name="ExplanationLevelComboBox" />
          <TextBlock Foreground="#D7E2EA" Text="Narration style" />
          <ComboBox x:Name="NarrationStyleComboBox" />
        </StackPanel>
        <TextBlock x:Name="ModeDescriptionTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="#D7E2EA"
                   TextWrapping="Wrap" />
      </Grid>
    </Border>

    <StackPanel Grid.Row="1"
                Margin="0,14,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10">
      <Button Content="Cancel" Click="CancelButton_Click" />
      <Button Content="Save" Click="SaveButton_Click" />
    </StackPanel>
  </Grid>
</Window>
