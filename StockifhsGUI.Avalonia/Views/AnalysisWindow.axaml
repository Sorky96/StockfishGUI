<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StockifhsGUI.Avalonia.Views.AnalysisWindow"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Title="Imported Game Analysis"
        Background="{DynamicResource ChromeBrush}">
  <Grid Margin="18" RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="220,180,180,*,170,150">
      <ComboBox x:Name="SideComboBox" />
      <ComboBox x:Name="QualityFilterComboBox" Grid.Column="1" Margin="12,0,0,0" />
      <ComboBox x:Name="ExplanationLevelComboBox" Grid.Column="2" Margin="12,0,0,0" />
      <TextBlock x:Name="SummaryTextBlock"
                 Grid.Column="3"
                 Margin="16,0,0,0"
                 VerticalAlignment="Center"
                 Foreground="White"
                 TextWrapping="Wrap" />
      <Button x:Name="AnalyzeButton"
              Grid.Column="4"
              Margin="16,0,0,0"
              Click="AnalyzeButton_Click"
              Content="Run Analysis" />
      <Button x:Name="ShowOnBoardButton"
              Grid.Column="5"
              Margin="12,0,0,0"
              Click="ShowOnBoardButton_Click"
              Content="Show On Board" />
    </Grid>

    <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="*,170">
      <StackPanel>
        <TextBlock x:Name="StatusTextBlock"
                   Foreground="#D7E2EA"
                   Text="Choose a side and run the analysis."
                   TextWrapping="Wrap" />
        <TextBlock x:Name="AdviceStatusTextBlock"
                   Margin="0,6,0,0"
                   Foreground="#9EB5C5"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Button x:Name="TestAdviceButton"
              Grid.Column="1"
              HorizontalAlignment="Right"
              Click="TestAdviceButton_Click"
              Content="Test Advice Model" />
    </Grid>

    <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="360,*">
      <Border Background="White" BorderBrush="#C9C9C9" BorderThickness="1" CornerRadius="8">
        <ListBox x:Name="MistakesListBox"
                 SelectionChanged="MistakesListBox_OnSelectionChanged"
                 DoubleTapped="MistakesListBox_OnDoubleTapped"
                 Background="White"
                 Foreground="Black"
                 BorderThickness="0">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Foreground" Value="Black" />
              <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="#DCE8F2" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="#AFC6D9" />
            </Style>
          </ListBox.Styles>
        </ListBox>
      </Border>

      <Border Grid.Column="1" Margin="14,0,0,0" Background="#101820" BorderBrush="#395061" BorderThickness="1" CornerRadius="8" Padding="12">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <TextBlock x:Name="DetailsTextBlock"
                     Foreground="White"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
