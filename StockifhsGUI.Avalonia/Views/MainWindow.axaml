<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StockifhsGUI.Avalonia.ViewModels"
        xmlns:controls="using:StockifhsGUI.Avalonia.Controls"
        x:Class="StockifhsGUI.Avalonia.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Width="1200"
        Height="720"
        MinWidth="1160"
        MinHeight="700"
        Background="{DynamicResource ChromeBrush}"
        Title="StockifhsGUI Avalonia">
  <Grid Margin="10" ColumnDefinitions="*,14,620" RowDefinitions="*">
    <Border Grid.RowSpan="2" Background="{DynamicResource PanelBrush}" CornerRadius="18" Padding="10">
      <Grid RowDefinitions="*,Auto,Auto">
        <Viewbox Stretch="Uniform"
                 StretchDirection="Both"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
          <controls:ChessBoardView x:Name="BoardView"
                                   Width="540"
                                   Height="540"
                                   Fen="{Binding BoardFen}"
                                   RotateBoard="{Binding RotateBoard}"
                                   SelectedSquare="{Binding SelectedSquareName}"
                                   PreviewTargetSquare="{Binding PreviewTargetSquare}"
                                   AvailableMoves="{Binding AvailableMoveSquares}"
                                   Arrows="{Binding BestMoveArrows}"
                                   SquarePressed="BoardView_OnSquarePressed" />
        </Viewbox>

        <StackPanel Grid.Row="1" Margin="10,8,10,0" Spacing="6">
          <TextBlock Foreground="White" FontSize="16" Text="{Binding SuggestionText}" />
          <TextBlock Foreground="White" FontSize="16" Text="{Binding EvaluationText}" />
          <ProgressBar Minimum="0" Maximum="100" Height="18" Value="{Binding EvaluationBarValue}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10,12,10,10" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
          <Button Width="140" Command="{Binding RotateBoardCommand}" Content="ROTATE BOARD" />
          <Button Width="100" Command="{Binding UndoCommand}" Content="UNDO" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Column="2" Grid.RowSpan="2" Background="{DynamicResource PanelBrush}" CornerRadius="18" Padding="10">
      <Grid Margin="10" RowDefinitions="Auto,14,*" ColumnDefinitions="*,*">
        <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <Button Grid.Row="0" Grid.Column="0" Height="36" Margin="0,0,6,0" HorizontalAlignment="Stretch" Click="PgnImportButton_Click" Content="PASTE PGN" />
          <Button Grid.Row="0" Grid.Column="1" Height="36" Margin="6,0,0,0" HorizontalAlignment="Stretch" Click="LoadSavedButton_Click" Content="LOAD SAVED" />

          <Button Grid.Row="1" Grid.Column="0" Height="36" Margin="0,8,6,0" HorizontalAlignment="Stretch" Command="{Binding ApplyNextImportedMoveCommand}" Content="APPLY NEXT" />
          <Button Grid.Row="1" Grid.Column="1" Height="36" Margin="6,8,0,0" HorizontalAlignment="Stretch" Command="{Binding ApplySelectedImportedMoveCommand}" Content="APPLY SELECTED" />

          <Button Grid.Row="2" Grid.Column="0" Height="36" Margin="0,8,6,0" HorizontalAlignment="Stretch" Click="AnalyzeImportedButton_Click" Content="ANALYZE IMPORTED" />
          <Button Grid.Row="2" Grid.Column="1" Height="36" Margin="6,8,0,0" HorizontalAlignment="Stretch" Click="ProfilesButton_Click" Content="PROFILES" />

          <Button Grid.Row="3"
                  Grid.Column="0"
                  Height="36"
                  Margin="0,8,6,0"
                  HorizontalAlignment="Stretch"
                  Click="SavedAnalysesButton_Click"
                  Content="SAVED ANALYSES" />
          <Button Grid.Row="3"
                  Grid.Column="1"
                  Height="36"
                  Margin="6,8,0,0"
                  HorizontalAlignment="Stretch"
                  Click="SettingsButton_Click"
                  Content="SETTINGS" />
        </Grid>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*">
          <Grid RowDefinitions="32,*" Margin="0,0,6,0">
            <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="16" Text="{Binding ImportedGameSummary}" />
            <Border Grid.Row="1" Background="White" BorderBrush="#C9C9C9" BorderThickness="1">
              <ListBox ItemsSource="{Binding ImportedMoves}"
                       SelectedItem="{Binding SelectedImportedMove}"
                       Background="White"
                       Foreground="Black"
                       BorderThickness="0">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="Background" Value="Transparent" />
                  </Style>
                  <Style Selector="ListBoxItem ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="Background" Value="#DCE8F2" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="Background" Value="#AFC6D9" />
                  </Style>
                  <Style Selector="ListBoxItem:selected ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ImportedMoveItemViewModel">
                    <TextBlock Margin="6,2"
                               Foreground="Black"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               Text="{Binding DisplayText}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>

          <Grid Grid.Column="1" RowDefinitions="32,*" Margin="6,0,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="16" Text="{Binding PieceMoveOptionsHeader}" />
            <Border Grid.Row="1" Background="White" BorderBrush="#C9C9C9" BorderThickness="1">
              <ListBox ItemsSource="{Binding PieceMoveOptions}"
                       SelectedItem="{Binding SelectedPieceMoveOption}"
                       Background="White"
                       Foreground="Black"
                       BorderThickness="0">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="Background" Value="Transparent" />
                  </Style>
                  <Style Selector="ListBoxItem ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="Background" Value="#DCE8F2" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected">
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="Background" Value="#AFC6D9" />
                  </Style>
                  <Style Selector="ListBoxItem:selected ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover TextBlock">
                    <Setter Property="Foreground" Value="Black" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:PieceMoveOptionViewModel">
                    <TextBlock Margin="6,2"
                               Foreground="Black"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               Text="{Binding Label}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
