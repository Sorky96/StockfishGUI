    <ProjectReference Include="..\MoveMentorChess.Presentation\MoveMentorChess.Presentation.csproj" />
    <ProjectReference Include="..\MoveMentorChess.Profiles\MoveMentorChess.Profiles.csproj" />
    <ProjectReference Include="..\MoveMentorChess.Training\MoveMentorChess.Training.csproj" />
    <ProjectReference Include="..\MoveMentorChess.Tracking\MoveMentorChess.Tracking.csproj" />
  </ItemGroup>

  <ItemGroup>
