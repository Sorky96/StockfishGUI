<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MoveMentorChess.App.ViewModels"
        xmlns:controls="using:MoveMentorChess.App.Controls"
        xmlns:domain="using:MoveMentorChess.Domain"
        x:Class="MoveMentorChess.App.Views.OpeningTrainerWindow"
        x:DataType="vm:OpeningTrainerWindowViewModel"
        Width="1380"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowState="FullScreen"
        SystemDecorations="None"
        Background="{DynamicResource ChromeBrush}"
        Title="Opening Trainer"
        mc:Ignorable="d">
  <Grid Margin="12" RowDefinitions="Auto,12,*">
    <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <StackPanel Spacing="4">
            <TextBlock Foreground="White" FontSize="24" FontWeight="Bold" Text="Opening Trainer" />
            <TextBlock Foreground="#D7E2EA" FontSize="16" Text="{Binding StageTitle}" />
            <TextBlock Foreground="#9EB5C5" Text="{Binding StageDescription}" TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="1" Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="14,10" MinWidth="210">
            <StackPanel Spacing="6">
              <TextBlock Foreground="#D7E2EA" HorizontalAlignment="Center" Text="Training Progress" />
              <ProgressBar Minimum="0" Maximum="100" Value="{Binding StageProgressPercent}" Height="10" />
              <TextBlock Foreground="White" HorizontalAlignment="Center" Text="{Binding StageProgressLabel}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Button Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top"
                  MinWidth="96"
                  Click="CloseButton_Click"
                  Content="Close" />
        </Grid>
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <ScrollViewer IsVisible="{Binding IsSelectionPageVisible}">
        <StackPanel Spacing="12">
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="22">
          <Grid MaxWidth="1120" HorizontalAlignment="Center" RowDefinitions="Auto,16,Auto">
            <Grid ColumnDefinitions="*,300" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Foreground="#9ED7A6" FontSize="15" FontWeight="SemiBold" Text="Today's recommendation" />
              <TextBlock Grid.Row="1" Foreground="White" FontSize="32" FontWeight="Bold" Text="{Binding TodayLessonOpening}" TextWrapping="Wrap" />
              <TextBlock Grid.Row="2" Margin="0,10,28,0" Foreground="#D7E2EA" FontSize="16" Text="{Binding TodayDecisionSummary}" TextWrapping="Wrap" />

              <Border Grid.Column="1" Grid.RowSpan="3" Background="{DynamicResource ChromeBrush}" CornerRadius="12" Padding="14">
                <StackPanel Spacing="10">
                  <Border HorizontalAlignment="Left" Background="#284F38" CornerRadius="8" Padding="9,4">
                    <TextBlock Foreground="#9ED7A6" FontSize="12" FontWeight="SemiBold" Text="Recommended" />
                  </Border>
                  <Button MinHeight="52"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Center"
                          FontSize="17"
                          FontWeight="SemiBold"
                          Background="#2F7D4E"
                          Foreground="White"
                          Command="{Binding StartRecommendedStudyCommand}"
                          Content="{Binding TodayLessonButtonText}"
                          IsEnabled="{Binding HasTodayLesson}" />
                  <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding TodayStartSequenceText}" TextWrapping="Wrap" />
                  <Button HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Center"
                          Command="{Binding GoToOverviewCommand}"
                          Content="Review plan before starting" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <Border Margin="0,0,8,0" Background="{DynamicResource ChromeBrush}" CornerRadius="12" Padding="14">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="Why this matters" />
                  <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="{Binding TodayTrainingReasonLabel}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" FontSize="15" Text="{Binding TodayLessonReasonDetail}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Margin="8,0,0,0" Background="{DynamicResource ChromeBrush}" CornerRadius="12" Padding="14">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="What you will practice" />
                  <TextBlock Foreground="White" FontSize="15" FontWeight="SemiBold" Text="{Binding PracticeFocusText}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" FontSize="15" Text="{Binding OpeningContextStartsFrom}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0" Background="{DynamicResource ChromeBrush}" CornerRadius="12" Padding="12">
                <Grid ColumnDefinitions="220,*,260" RowDefinitions="Auto">
                  <StackPanel Spacing="2">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="Training intensity" />
                    <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding SelectedIntensitySummary}" TextWrapping="Wrap" />
                  </StackPanel>
                  <ComboBox Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="12,0"
                            ItemsSource="{Binding AvailableIntensityChoices}"
                            SelectedItem="{Binding SelectedIntensityChoice}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:OpeningTrainingIntensityChoice">
                        <StackPanel Spacing="2">
                          <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding Description}" TextWrapping="Wrap" />
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <ComboBox Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            ItemsSource="{Binding AvailableProfileChoices}"
                            SelectedItem="{Binding SelectedProfileChoice}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:OpeningTrainingProfileChoice">
                        <StackPanel Spacing="2">
                          <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding Description}" TextWrapping="Wrap" />
                        </StackPanel>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Border>

        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="18">
          <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*">
              <StackPanel Spacing="4">
                <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedOpeningName}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9EB5C5" FontSize="14" Text="{Binding SelectedOpeningSideText}" />
              </StackPanel>
            </Grid>

            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="10">
                <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="Due now" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding PlayerOpeningPlanSummary}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9EB5C5" Text="{Binding PlayerOpeningProgressInterpretation}" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*,*">
                  <StackPanel Spacing="6" Margin="0,0,6,0">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="Today's recommendation" />
                    <ItemsControl ItemsSource="{Binding TodayPlanItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="domain:PlayerOpeningPlanItem">
                          <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" Text="{Binding Detail}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="6" Margin="6,0">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="This week's practice" />
                    <ItemsControl ItemsSource="{Binding WeeklyPlanItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="domain:PlayerOpeningPlanItem">
                          <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" Text="{Binding Evidence}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="6" Margin="6,0,0,0">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="Later / optional repairs" />
                    <ItemsControl ItemsSource="{Binding LongTermGapItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="domain:PlayerOpeningPlanItem">
                          <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" Text="{Binding Evidence}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*,*">
              <Border Margin="0,0,6,6" Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9EB5C5" Text="Your current coverage" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding CoverageHumanText}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding CoverageMetricText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Margin="6,0,6,6" Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="8">
                  <TextBlock Foreground="#9EB5C5" Text="Opening map" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding OpeningContextStartsFrom}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding OpeningContextPlan}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Margin="6,0,0,6" Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9EB5C5" Text="Opponent replies" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Most common replies" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding OpponentSummary}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

            <Expander Header="Advanced Options" IsExpanded="{Binding IsAdvancedOptionsExpanded}">
              <Grid ColumnDefinitions="300,12,*,12,300" Margin="0,8,0,0" MinHeight="260" MaxHeight="320">
                <Border Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Opening Catalog" />
                    <TextBlock Foreground="#9EB5C5" Text="Choose a specific line when you want to train outside today's lesson." TextWrapping="Wrap" />
                    <TextBox Watermark="Filter openings or ECO" Text="{Binding FilterText}" />
                    <TextBox Watermark="Override history key (optional)" Text="{Binding AdvancedPlayerKey}" />
                    <TextBlock Foreground="#9EB5C5" Text="{Binding PlayerKey, StringFormat='Active history key: {0}'}" TextWrapping="Wrap" />
                    <ComboBox ItemsSource="{Binding AvailableSides}" SelectedItem="{Binding SelectedSide}" />
                    <ComboBox ItemsSource="{Binding AvailableStrictnessOptions}" SelectedItem="{Binding SelectedStrictness}" />
                    <Grid ColumnDefinitions="*,*">
                      <Button Margin="0,0,5,0" Command="{Binding RefreshCommand}" Content="Refresh" />
                      <Button Grid.Column="1" Margin="5,0,0,0" Command="{Binding GoToOverviewCommand}" Content="See Plan" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="14">
                  <ListBox ItemsSource="{Binding OpeningItems}" SelectedItem="{Binding SelectedOpening}" Background="{DynamicResource ChromeBrush}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="domain:OpeningLineCatalogItem">
                        <StackPanel Margin="8,6" Spacing="2">
                          <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding DisplayName}" TextWrapping="Wrap" />
                          <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding RepertoireSide}" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <Border Grid.Column="4" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                  <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Special Modes" />
                    <ComboBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding SpecialTrainingModes}" SelectedItem="{Binding SelectedSpecialMode}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:SpecialTrainingModeDefinition">
                          <StackPanel Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding TimeLimitMinutes}" />
                          </StackPanel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Margin="0,10,0,0" Foreground="#9EB5C5" Text="{Binding SelectedSpecialModeDescription}" TextWrapping="Wrap" />
                    <Button Grid.Row="3" Command="{Binding StartSpecialModeCommand}" Content="{Binding SelectedSpecialModeButtonText}" />
                  </Grid>
                </Border>
              </Grid>
            </Expander>
          </StackPanel>
        </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid IsVisible="{Binding IsOverviewPageVisible}" ColumnDefinitions="430,12,*">
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
          <StackPanel Spacing="10">
            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Understand The Idea" />
            <controls:ChessBoardView Width="396"
                                     Height="396"
                                     Fen="{Binding PreviewFen}"
                                     Arrows="{Binding PreviewArrows}"
                                     RotateBoard="{Binding IsBoardRotated}"
                                     IsHitTestVisible="False" />
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <StackPanel Spacing="6">
                <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding OpponentSummary}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9ED7A6" Text="{Binding CoverageExplanation}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <StackPanel Spacing="8">
              <Button MinHeight="52"
                      FontWeight="SemiBold"
                      Background="#2F7D4E"
                      Foreground="White"
                      Command="{Binding StartGuidedStudyCommand}"
                      Content="Start Practice From Memory" />
              <Button HorizontalAlignment="Left"
                      Background="Transparent"
                      Command="{Binding GoToSelectionCommand}"
                      Content="Back" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*,*">
          <Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
              <StackPanel Spacing="6">
                <TextBlock Foreground="#9EB5C5" Text="Your saved progress" />
                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding CoverageText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding CoverageExplanation}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
              <StackPanel Spacing="6">
                <TextBlock Foreground="#9EB5C5" Text="Why This Line Works" />
                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Remember this" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding RememberThisText}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="1" Margin="0,0,0,12" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Plan Before Moves" />
              <ItemsControl ItemsSource="{Binding UnderstandingCards}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="domain:OpeningUnderstandingCard">
                    <Border Width="300" MinHeight="120" Margin="0,0,10,10" Background="{DynamicResource ChromeBrush}" CornerRadius="12" Padding="12">
                      <StackPanel Spacing="6">
                        <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                        <TextBlock Foreground="#D7E2EA" Text="{Binding Body}" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Grid Grid.Row="2" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Line To Remember" />
                <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding MainLineText}" TextWrapping="Wrap" />
                    <TextBlock Foreground="#9EB5C5" Text="Move notes appear only as short tags while you review the line." TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Opponent Replies" />
                <ListBox ItemsSource="{Binding BranchItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="3" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Today's Focus" />
              <TextBlock Grid.Row="1" Foreground="#9EB5C5" Text="{Binding PriorityItemsPlaceholder}" TextWrapping="Wrap" />
              <ListBox Grid.Row="2"
                       ItemsSource="{Binding PriorityItems}"
                       SelectedItem="{Binding SelectedPriority}"
                       Background="{DynamicResource ChromeBrush}"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="domain:TrainingPriorityItem">
                    <Grid Margin="8,6" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                      <TextBlock Grid.Column="1" Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding PriorityLabel}" />
                      <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#D7E2EA" Text="{Binding Summary}" TextWrapping="Wrap" />
                      <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="#9EB5C5" Text="{Binding Evidence}" TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Button Grid.Row="3" Margin="0,8,0,0" Command="{Binding StartPriorityStudyCommand}" Content="{Binding SelectedPriorityActionText}" />
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Grid IsVisible="{Binding IsStudyPageVisible}" ColumnDefinitions="*,12,360">
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
          <Grid RowDefinitions="Auto,Auto,Auto,*">
            <Grid ColumnDefinitions="*,220">
              <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Practice From Memory" />
              <ProgressBar Grid.Column="1"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding StudyProgressPercent}"
                           Height="10"
                           VerticalAlignment="Center" />
            </Grid>
            <Border Grid.Row="1" Margin="0,8,0,10" Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="{Binding StudyTaskTitle}" TextWrapping="Wrap" />
                <TextBlock Grid.Column="1" Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding StudyTaskSubtitle}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0" Foreground="#D7E2EA" Text="{Binding StudyMovePromptText}" TextWrapping="Wrap" />
              </Grid>
            </Border>
            <Border Grid.Row="2" Margin="0,0,0,8" Background="#14222D" CornerRadius="10" Padding="10,6" HorizontalAlignment="Center">
              <TextBlock Foreground="#D7E2EA" FontWeight="SemiBold" Text="{Binding StudyBoardStatusText}" TextWrapping="Wrap" />
            </Border>
            <Viewbox Grid.Row="3" Stretch="Uniform" MaxWidth="620" MaxHeight="620">
              <Grid Width="580" Height="580">
                <controls:ChessBoardView Width="580"
                                         Height="580"
                                         Fen="{Binding PreviewFen}"
                                         RotateBoard="{Binding IsBoardRotated}"
                                         SelectedSquare="{Binding StudySelectedSquare}"
                                         PreviewTargetSquare="{Binding StudyPreviewTargetSquare}"
                                         AvailableMoves="{Binding StudyAvailableMoveSquares}"
                                         Arrows="{Binding PreviewArrows}"
                                         SquarePressed="OnStudyBoardSquarePressed" />
                <Border Background="{Binding StudyFeedbackBrush}"
                        BorderBrush="{Binding StudyFeedbackBorderBrush}"
                        BorderThickness="6"
                        Opacity="{Binding StudyFeedbackOpacity}"
                        IsHitTestVisible="False">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="White"
                             FontSize="34"
                             FontWeight="Bold"
                             Text="{Binding StudyFeedbackText}" />
                </Border>
              </Grid>
            </Viewbox>
          </Grid>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,Auto,*,Auto">
          <Border Margin="0,0,0,12" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
            <StackPanel Spacing="10">
              <StackPanel Spacing="2">
                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Your move" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding StudySideToMoveText}" TextWrapping="Wrap" />
              </StackPanel>
              <TextBlock Foreground="#D7E2EA" Text="{Binding StudyBoardHint}" TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,*,*">
                <Border Margin="0,0,5,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <StackPanel Spacing="2">
                    <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding SessionCorrectCountText}" />
                    <TextBlock Foreground="#9EB5C5" FontSize="12" Text="clear moves" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="5,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <StackPanel Spacing="2">
                    <TextBlock Foreground="#D7E2EA" FontWeight="SemiBold" Text="{Binding SessionAcceptedAlternativesText}" />
                    <TextBlock Foreground="#9EB5C5" FontSize="12" Text="still useful" />
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Margin="5,0,0,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <StackPanel Spacing="2">
                    <TextBlock Foreground="#F5D97B" FontWeight="SemiBold" Text="{Binding SessionNeedsReviewText}" />
                    <TextBlock Foreground="#9EB5C5" FontSize="12" Text="repeat targets" />
                  </StackPanel>
                </Border>
              </Grid>
              <Border Background="#14222D" CornerRadius="12" Padding="12">
                <TextBlock Foreground="#F5D97B" Text="{Binding StudyFeedbackSummaryText}" TextWrapping="Wrap" />
              </Border>
              <Border IsVisible="{Binding HasAnswerOptions}" Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
                <StackPanel Spacing="8">
                  <ListBox ItemsSource="{Binding AnswerOptionItems}"
                           SelectedItem="{Binding SelectedAnswerOption}"
                           Background="#14222D"
                           BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="domain:OpeningTrainingAnswerOption">
                        <TextBlock Margin="8,6" Foreground="#F5FAFD" Text="{Binding Text}" TextWrapping="Wrap" />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <Button Command="{Binding EvaluateMoveCommand}" Content="Submit Answer" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding CurrentHintLevel}" TextWrapping="Wrap" />
                    <Button Grid.Column="1" MinWidth="86" FontWeight="SemiBold" Command="{Binding ShowHintCommand}" Content="Hint" />
                    <Button Grid.Column="2" Margin="6,0,0,0" Command="{Binding DontKnowCommand}" Content="{Binding DontKnowButtonText}" />
                  </Grid>
                  <TextBlock Foreground="#D7E2EA" Text="{Binding CurrentHintText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Grid.Row="1" IsVisible="{Binding IsStudyReferenceHidden}" Margin="0,0,0,12" Background="{DynamicResource PanelBrush}" CornerRadius="12" Padding="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Try From Memory First" />
                <TextBlock Foreground="#9EB5C5" Text="{Binding StudyReferencePromptText}" TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1" Margin="12,0,0,0" Command="{Binding RevealStudyReferenceCommand}" Content="{Binding StudyReferenceButtonText}" />
            </Grid>
          </Border>

          <Grid Grid.Row="1" IsVisible="{Binding IsStudyReferenceVisible}" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Line Reference" />
                <ListBox ItemsSource="{Binding MainLineItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Opponent Replies" />
                <ListBox ItemsSource="{Binding BranchItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2" Margin="0,0,0,12" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="What This Position Trains" />
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding CurrentPositionGoalText}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding CurrentMoveTrainingPurposeText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9EB5C5" Text="Attempt history" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding CurrentAttemptHistoryText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <TextBlock Foreground="#9EB5C5" Text="{Binding StudyInputModeText}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="*,*">
            <Button Margin="0,0,6,0" Command="{Binding PreviousStepCommand}" Content="Previous Position" />
            <Button Grid.Column="1" Margin="6,0,0,0" Command="{Binding RestartStudyCommand}" Content="Restart Study" />
          </Grid>
        </Grid>
      </Grid>

      <Grid IsVisible="{Binding IsResultsPageVisible}" ColumnDefinitions="*,*">
        <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="Review And Continue" />
            <Border Background="#14222D" CornerRadius="12" Padding="14">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Foreground="White" FontSize="24" FontWeight="Bold" Text="{Binding ResultCelebrationTitle}" TextWrapping="Wrap" />
                  <Border Grid.Column="1" Background="#2F7D4E" CornerRadius="10" Padding="10,5">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding ResultOutcomeBadge}" />
                  </Border>
                </Grid>
                <TextBlock Foreground="#D7E2EA" FontSize="15" Text="{Binding ResultCelebrationText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9ED7A6" Text="{Binding ResultNextStepSummary}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*,*,*,*">
              <Border Margin="0,0,5,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="Completed" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ResultsCompletedMetricText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Margin="5,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="Clear" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ResultsClearMetricText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Margin="5,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#D7E2EA" FontWeight="SemiBold" Text="Useful alternatives" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ResultsAlternativesMetricText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="3" Margin="5,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9EB5C5" FontWeight="SemiBold" Text="Hints used" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ResultsHintsMetricText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Margin="5,0,0,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#F5D97B" FontWeight="SemiBold" Text="To revisit" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ResultsRevisitMetricText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="#9EB5C5" Text="Main repair point" />
                <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding ResultsBiggestWeaknessText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding LearningPlanReasonText}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="#9EB5C5" Text="Review Focus" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding LearningPlanReviewPlaceholder}" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding LearningPlanReviewItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="domain:TrainingResultReviewItem">
                      <Grid Margin="0,4" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                        <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding MoveText}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Foreground="#F5D97B" Text="{Binding PriorityText}" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#D7E2EA" Text="{Binding AttemptedMoveText, StringFormat='Attempted: {0}'}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="#D7E2EA" Text="{Binding PreparedMoveText, StringFormat='Prepared move: {0}'}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Foreground="#9EB5C5" Text="{Binding ReasonText, StringFormat='Reason: {0}'}" TextWrapping="Wrap" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Button HorizontalAlignment="Left" MinWidth="120" Command="{Binding GoToOverviewCommand}" Content="Back to overview" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
            <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Choose Your Next Training Plan" />
            <TextBlock Grid.Row="1" Foreground="#9EB5C5" Text="{Binding NextActionsPlaceholder}" TextWrapping="Wrap" />
            <Border Grid.Row="2" IsVisible="{Binding HasPrimaryNextAction}" Margin="0,10,0,12" Background="{DynamicResource ChromeBrush}" CornerRadius="12" Padding="14">
              <StackPanel Spacing="8">
                <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="Recommended next" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding PrimaryNextAction.Title}" TextWrapping="Wrap" />
                  <TextBlock Grid.Column="1" Foreground="#9ED7A6" FontWeight="SemiBold" Text="recommended" />
                </Grid>
                <TextBlock Foreground="#D7E2EA" Text="{Binding PrimaryNextAction.Reason}" TextWrapping="Wrap" />
                <Button MinHeight="48"
                        FontWeight="SemiBold"
                        Background="#2F7D4E"
                        Foreground="White"
                        Command="{Binding ExecutePrimaryNextActionCommand}"
                        Content="{Binding PrimaryNextAction.ButtonText}" />
              </StackPanel>
            </Border>
            <StackPanel Grid.Row="3" IsVisible="{Binding HasSecondaryNextActions}" Spacing="8" Margin="0,0,0,12">
              <TextBlock Foreground="#9EB5C5" Text="Other useful choices" />
              <ListBox ItemsSource="{Binding SecondaryNextActionCards}"
                       SelectedItem="{Binding SelectedSecondaryNextAction}"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:TrainingNextActionCardViewModel">
                    <Border Margin="0,0,0,8" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12">
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1" Foreground="#9EB5C5" Text="{Binding TimingText}" />
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#D7E2EA" Text="{Binding Reason}" TextWrapping="Wrap" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Button HorizontalAlignment="Left"
                      Command="{Binding ExecuteSelectedSecondaryNextActionCommand}"
                      Content="{Binding SelectedSecondaryNextAction.ButtonText}" />
            </StackPanel>
            <StackPanel Grid.Row="4" Spacing="8" Margin="0,0,0,8">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Session Recap" />
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                <Border Margin="0,0,4,4" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="#9EB5C5" Text="Completed" />
                    <TextBlock Grid.Column="1" Foreground="White" FontWeight="SemiBold" Text="{Binding ResultsCompletedMetricText}" />
                  </Grid>
                </Border>
                <Border Grid.Column="1" Margin="4,0,0,4" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="#9EB5C5" Text="Clear" />
                    <TextBlock Grid.Column="1" Foreground="White" FontWeight="SemiBold" Text="{Binding ResultsClearMetricText}" />
                  </Grid>
                </Border>
                <Border Grid.Row="1" Margin="0,4,4,4" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="#9EB5C5" Text="Useful alternatives" />
                    <TextBlock Grid.Column="1" Foreground="White" FontWeight="SemiBold" Text="{Binding ResultsAlternativesMetricText}" />
                  </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Margin="4,4,0,4" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="#9EB5C5" Text="Hints used" />
                    <TextBlock Grid.Column="1" Foreground="White" FontWeight="SemiBold" Text="{Binding ResultsHintsMetricText}" />
                  </Grid>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0" Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="10">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="#F5D97B" Text="To revisit" />
                    <TextBlock Grid.Column="1" Foreground="White" FontWeight="SemiBold" Text="{Binding ResultsRevisitMetricText}" />
                  </Grid>
                </Border>
              </Grid>
              <TextBlock Foreground="#9EB5C5" Text="{Binding ResultRecommendation}" TextWrapping="Wrap" />
            </StackPanel>
            <Expander Grid.Row="5" Header="Advanced Details" IsVisible="{Binding HasAdvancedResultDetails}">
              <StackPanel Spacing="10" Margin="0,8,0,0">
                <TextBlock Foreground="#9EB5C5" Text="Diagnostic review positions" />
                <ItemsControl ItemsSource="{Binding LearningPlanReviewItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="domain:TrainingResultReviewItem">
                      <Grid Margin="0,4" ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Foreground="#9EB5C5" Text="PositionId" />
                        <TextBlock Grid.Column="1" Foreground="#D7E2EA" Text="{Binding PositionId}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Foreground="#9EB5C5" Text="Attempt" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#D7E2EA" Text="{Binding AttemptedMoveText}" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2" Foreground="#9EB5C5" Text="Reason" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Foreground="#D7E2EA" Text="{Binding ReasonText}" TextWrapping="Wrap" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Foreground="#9EB5C5" Text="{Binding TranspositionSummaryText}" TextWrapping="Wrap" />
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Move Log" />
                <ListBox ItemsSource="{Binding ResultItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Expander>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
