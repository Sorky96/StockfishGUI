<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MoveMentorChess.App.ViewModels"
        xmlns:controls="using:MoveMentorChess.App.Controls"
        xmlns:domain="using:MoveMentorChess.Domain"
        x:Class="MoveMentorChess.App.Views.OpeningTrainerWindow"
        x:DataType="vm:OpeningTrainerWindowViewModel"
        Width="1380"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowState="FullScreen"
        SystemDecorations="None"
        Background="{DynamicResource ChromeBrush}"
        Title="Opening Trainer"
        mc:Ignorable="d">
  <Grid Margin="12" RowDefinitions="Auto,12,*">
    <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <StackPanel Spacing="4">
            <TextBlock Foreground="White" FontSize="24" FontWeight="Bold" Text="Opening Trainer" />
            <TextBlock Foreground="#D7E2EA" FontSize="16" Text="{Binding StageTitle}" />
            <TextBlock Foreground="#9EB5C5" Text="{Binding StageDescription}" TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="1" Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="14,10" MinWidth="210">
            <StackPanel Spacing="6">
              <TextBlock Foreground="#D7E2EA" HorizontalAlignment="Center" Text="Flow Progress" />
              <ProgressBar Minimum="0" Maximum="100" Value="{Binding StageProgressPercent}" Height="10" />
              <TextBlock Foreground="White" HorizontalAlignment="Center" Text="{Binding StageTitle}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Button Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top"
                  MinWidth="96"
                  Click="CloseButton_Click"
                  Content="Close" />
        </Grid>
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <ScrollViewer IsVisible="{Binding IsSelectionPageVisible}">
        <StackPanel Spacing="12">
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="22">
          <Grid ColumnDefinitions="*,240" RowDefinitions="Auto,Auto,Auto,Auto" MaxWidth="1320" HorizontalAlignment="Stretch">
            <TextBlock Foreground="#9ED7A6" FontSize="15" FontWeight="SemiBold" Text="Today's Lesson" />
            <TextBlock Grid.Row="1" Foreground="White" FontSize="32" FontWeight="Bold" Text="{Binding TodayLessonOpening}" TextWrapping="Wrap" />
            <WrapPanel Grid.Row="2" Margin="0,14,0,0">
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,8,0">
                <TextBlock Foreground="#D7E2EA" Text="{Binding TodayLessonSideText}" TextWrapping="Wrap" />
              </Border>
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,8,0">
                <TextBlock Foreground="#D7E2EA" Text="{Binding TodayLessonDurationText}" TextWrapping="Wrap" />
              </Border>
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="10" Padding="12,8">
                <TextBlock Foreground="#D7E2EA" Text="{Binding TodayLessonMoveCountText}" TextWrapping="Wrap" />
              </Border>
            </WrapPanel>
            <TextBlock Grid.Row="3" Foreground="#9EB5C5" Margin="0,16,28,0" FontSize="15" Text="{Binding TodayLessonReason}" TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Grid.RowSpan="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    MinHeight="54"
                    Command="{Binding StartRecommendedStudyCommand}"
                    Content="{Binding TodayLessonButtonText}"
                    IsEnabled="{Binding HasTodayLesson}" />
          </Grid>
        </Border>

        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="18">
          <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4">
                <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedOpeningName}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9EB5C5" FontSize="14" Text="{Binding SelectedOpeningSideText}" />
              </StackPanel>
              <Button Grid.Column="1" VerticalAlignment="Center" Command="{Binding GoToOverviewCommand}" Content="View Opening Plan" />
            </Grid>

            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
              <StackPanel Spacing="10">
                <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding PlayerOpeningPlanTitle}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding PlayerOpeningPlanSummary}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9EB5C5" Text="{Binding PlayerOpeningProgressText}" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*,*">
                  <StackPanel Spacing="6" Margin="0,0,6,0">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="Today" />
                    <ItemsControl ItemsSource="{Binding TodayPlanItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="domain:PlayerOpeningPlanItem">
                          <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" Text="{Binding Detail}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="6" Margin="6,0">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="This Week" />
                    <ItemsControl ItemsSource="{Binding WeeklyPlanItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="domain:PlayerOpeningPlanItem">
                          <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" Text="{Binding Evidence}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="6" Margin="6,0,0,0">
                    <TextBlock Foreground="White" FontWeight="SemiBold" Text="Long-Term Gaps" />
                    <ItemsControl ItemsSource="{Binding LongTermGapItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="domain:PlayerOpeningPlanItem">
                          <StackPanel Margin="0,4" Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" Text="{Binding Evidence}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <Border Margin="0,0,6,6" Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9EB5C5" Text="Coverage Snapshot" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding CoverageText}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding CoverageExplanation}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Column="1" Margin="6,0,0,6" Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="6">
                  <TextBlock Foreground="#9EB5C5" Text="Opponent Prep" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Most common replies" />
                  <TextBlock Foreground="#D7E2EA" Text="{Binding OpponentSummary}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0" Background="{DynamicResource ChromeBrush}" CornerRadius="16" Padding="14">
                <StackPanel Spacing="8">
                  <TextBlock Foreground="#9EB5C5" Text="Selected Opening Preview" />
                  <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                  <TextBlock Foreground="#D7E2EA" Text="Continue to the overview page to inspect the main line, branches, and weak spots before you start the guided study." TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </Grid>

            <Expander Header="Advanced" IsExpanded="{Binding IsAdvancedOptionsExpanded}">
              <Grid ColumnDefinitions="300,12,*,12,300" Margin="0,8,0,0" MinHeight="260" MaxHeight="320">
                <Border Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                  <StackPanel Spacing="8">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Opening Catalog" />
                    <TextBlock Foreground="#9EB5C5" Text="Choose a specific line when you want to train outside today's lesson." TextWrapping="Wrap" />
                    <TextBox Watermark="Filter openings or ECO" Text="{Binding FilterText}" />
                    <TextBox Watermark="Player key for coverage/history (optional)" Text="{Binding PlayerKey}" />
                    <ComboBox ItemsSource="{Binding AvailableSides}" SelectedItem="{Binding SelectedSide}" />
                    <ComboBox ItemsSource="{Binding AvailableStrictnessOptions}" SelectedItem="{Binding SelectedStrictness}" />
                    <Grid ColumnDefinitions="*,*">
                      <Button Margin="0,0,5,0" Command="{Binding RefreshCommand}" Content="REFRESH" />
                      <Button Grid.Column="1" Margin="5,0,0,0" Command="{Binding GoToOverviewCommand}" Content="OPEN PLAN" />
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="14">
                  <ListBox ItemsSource="{Binding OpeningItems}" SelectedItem="{Binding SelectedOpening}" Background="{DynamicResource ChromeBrush}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="domain:OpeningLineCatalogItem">
                        <StackPanel Margin="8,6" Spacing="2">
                          <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding DisplayName}" TextWrapping="Wrap" />
                          <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding RepertoireSide}" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <Border Grid.Column="4" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="14" Padding="12">
                  <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Special Modes" />
                    <ComboBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding SpecialTrainingModes}" SelectedItem="{Binding SelectedSpecialMode}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:SpecialTrainingModeDefinition">
                          <StackPanel Spacing="2">
                            <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock Foreground="#9EB5C5" FontSize="12" Text="{Binding TimeLimitMinutes}" />
                          </StackPanel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Margin="0,10,0,0" Foreground="#9EB5C5" Text="{Binding SelectedSpecialModeDescription}" TextWrapping="Wrap" />
                    <Button Grid.Row="3" Command="{Binding StartSpecialModeCommand}" Content="{Binding SelectedSpecialModeButtonText}" />
                  </Grid>
                </Border>
              </Grid>
            </Expander>
          </StackPanel>
        </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid IsVisible="{Binding IsOverviewPageVisible}" ColumnDefinitions="430,12,*">
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
          <StackPanel Spacing="10">
            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="2. Opening Overview" />
            <controls:ChessBoardView Width="396"
                                     Height="396"
                                     Fen="{Binding PreviewFen}"
                                     Arrows="{Binding PreviewArrows}"
                                     IsHitTestVisible="False" />
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <StackPanel Spacing="6">
                <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding OpponentSummary}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9ED7A6" Text="{Binding CoverageExplanation}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*">
              <Button Margin="0,0,5,0" Command="{Binding GoToSelectionCommand}" Content="BACK TO SELECTION" />
              <Button Grid.Column="1" Margin="5,0,0,0" Command="{Binding StartGuidedStudyCommand}" Content="START GUIDED STUDY" />
            </Grid>
          </StackPanel>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,*,*">
          <Grid ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
              <StackPanel Spacing="6">
                <TextBlock Foreground="#9EB5C5" Text="Coverage" />
                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding CoverageText}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding CoverageExplanation}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
              <StackPanel Spacing="6">
                <TextBlock Foreground="#9EB5C5" Text="Why These Moves Matter" />
                <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="Book ideas and practical replies" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding OpponentSummary}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Main Line" />
                <ListBox ItemsSource="{Binding MainLineItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Opponent Branches" />
                <ListBox ItemsSource="{Binding BranchItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>
          </Grid>

          <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Training Priorities" />
              <TextBlock Grid.Row="1" Foreground="#9EB5C5" Text="{Binding PriorityItemsPlaceholder}" TextWrapping="Wrap" />
              <ListBox Grid.Row="2"
                       ItemsSource="{Binding PriorityItems}"
                       SelectedItem="{Binding SelectedPriority}"
                       Background="{DynamicResource ChromeBrush}"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="domain:TrainingPriorityItem">
                    <Grid Margin="8,6" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                      <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                      <TextBlock Grid.Column="1" Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding Score}" />
                      <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#D7E2EA" Text="{Binding Summary}" TextWrapping="Wrap" />
                      <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="#9EB5C5" Text="{Binding Evidence}" TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Button Grid.Row="3" Margin="0,8,0,0" Command="{Binding StartPriorityStudyCommand}" Content="{Binding SelectedPriorityActionText}" />
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Grid IsVisible="{Binding IsStudyPageVisible}" ColumnDefinitions="430,12,*">
        <Border Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
          <StackPanel Spacing="10">
            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="3. Guided Study" />
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding StudyProgressPercent}" Height="10" />
            <TextBlock Foreground="#D7E2EA" Text="{Binding StudyProgressText}" />
            <controls:ChessBoardView Width="396"
                                     Height="396"
                                     Fen="{Binding PreviewFen}"
                                     SelectedSquare="{Binding StudySelectedSquare}"
                                     PreviewTargetSquare="{Binding StudyPreviewTargetSquare}"
                                     AvailableMoves="{Binding StudyAvailableMoveSquares}"
                                     Arrows="{Binding PreviewArrows}"
                                     SquarePressed="OnStudyBoardSquarePressed" />
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <StackPanel Spacing="6">
                <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding CurrentPrompt}" TextWrapping="Wrap" />
                <TextBlock Foreground="#9ED7A6" Text="{Binding CurrentWhy}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
          <Border Margin="0,0,0,12" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Board Input" />
              <TextBlock Foreground="#D7E2EA" Text="{Binding StudyBoardHint}" TextWrapping="Wrap" />
              <TextBlock Foreground="#9EB5C5" Text="{Binding StudyInputModeText}" TextWrapping="Wrap" />
              <Border Background="#14222D" CornerRadius="12" Padding="12">
                <TextBlock Foreground="#F5D97B" Text="{Binding ResultText}" TextWrapping="Wrap" />
              </Border>
              <Border IsVisible="{Binding HasAnswerOptions}" Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
                <StackPanel Spacing="8">
                  <ListBox ItemsSource="{Binding AnswerOptionItems}"
                           SelectedItem="{Binding SelectedAnswerOption}"
                           Background="#14222D"
                           BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="domain:OpeningTrainingAnswerOption">
                        <TextBlock Margin="8,6" Foreground="#F5FAFD" Text="{Binding Text}" TextWrapping="Wrap" />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <Button Command="{Binding EvaluateMoveCommand}" Content="SUBMIT ANSWER" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Foreground="#9ED7A6" FontWeight="SemiBold" Text="{Binding CurrentHintLevel}" TextWrapping="Wrap" />
                    <Button Grid.Column="1" Command="{Binding ShowHintCommand}" Content="HINT" />
                  </Grid>
                  <TextBlock Foreground="#D7E2EA" Text="{Binding CurrentHintText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <Grid ColumnDefinitions="*,Auto">
                <Button Margin="0,0,8,0" Command="{Binding PreviousStepCommand}" Content="PREV STEP" />
                <Button Grid.Column="1" Command="{Binding RestartStudyCommand}" Content="RESTART" />
              </Grid>
              <TextBlock Foreground="#9EB5C5" Text="Moves are submitted directly from the board. Hints reveal the idea in layers before showing the full explanation." TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Main Line Reference" />
                <ListBox ItemsSource="{Binding MainLineItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Common Opponent Replies" />
                <ListBox ItemsSource="{Binding BranchItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
              </StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <Button Margin="0,0,6,0" Command="{Binding GoToOverviewCommand}" Content="BACK TO OVERVIEW" />
            <Button Grid.Column="1" Margin="6,0,0,0" Command="{Binding RestartStudyCommand}" Content="RESTART THIS STUDY" />
          </Grid>
        </Grid>
      </Grid>

      <Grid IsVisible="{Binding IsResultsPageVisible}" ColumnDefinitions="*,*">
        <Border Margin="0,0,6,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="4. Results" />
            <TextBlock Foreground="#D7E2EA" FontSize="16" Text="{Binding ResultHeadline}" TextWrapping="Wrap" />
            <TextBlock Foreground="White" FontSize="18" Text="{Binding ResultsSummaryText}" TextWrapping="Wrap" />
            <TextBlock Foreground="#9ED7A6" Text="{Binding TranspositionSummaryText}" TextWrapping="Wrap" />
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <TextBlock Foreground="#D7E2EA" Text="{Binding ResultRecommendation}" TextWrapping="Wrap" />
            </Border>
            <Border Background="{DynamicResource ChromeBrush}" CornerRadius="14" Padding="12">
              <StackPanel Spacing="6">
                <TextBlock Foreground="#9EB5C5" Text="Session Outcome" />
                <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding OutcomeSummary.Headline}" TextWrapping="Wrap" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding OutcomeSummary.AccuracyPercent, StringFormat='Accuracy {0:0.#}%'}" />
                <TextBlock Foreground="#D7E2EA" Text="{Binding OutcomeSummary.CompletionPercent, StringFormat='Completion {0:0.#}%'}" />
              </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,*">
              <Button Margin="0,0,6,0" Command="{Binding GoToOverviewCommand}" Content="BACK TO OVERVIEW" />
              <Button Grid.Column="1" Margin="6,0,0,0" Command="{Binding RestartStudyCommand}" Content="TRAIN THIS LINE AGAIN" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="6,0,0,0" Background="{DynamicResource PanelBrush}" CornerRadius="20" Padding="16">
          <Grid RowDefinitions="Auto,Auto,*,Auto,*,Auto">
            <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="Next Actions" />
            <TextBlock Grid.Row="1" Foreground="#9EB5C5" Text="{Binding NextActionsPlaceholder}" TextWrapping="Wrap" />
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding NextActionItems}"
                     SelectedItem="{Binding SelectedNextAction}"
                     Background="{DynamicResource ChromeBrush}"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="domain:TrainingNextAction">
                  <Grid Margin="8,6" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Foreground="#F5FAFD" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                    <TextBlock Grid.Column="1" Foreground="#9ED7A6" Text="{Binding DelayMinutes}" />
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Foreground="#D7E2EA" Text="{Binding Description}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="#9EB5C5" Text="{Binding CommandLabel}" TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <Button Grid.Row="3" Margin="0,8,0,12" Command="{Binding ExecuteNextActionCommand}" Content="{Binding SelectedNextActionButtonText}" />
            <StackPanel Grid.Row="4" Spacing="8">
              <TextBlock Foreground="White" FontSize="16" FontWeight="SemiBold" Text="Attempt Log" />
              <ListBox ItemsSource="{Binding ResultItems}" Background="{DynamicResource ChromeBrush}" BorderThickness="0" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
