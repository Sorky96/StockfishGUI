<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MoveMentorChess.App.ViewModels"
        xmlns:controls="using:MoveMentorChess.App.Controls"
        x:Class="MoveMentorChess.App.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Width="1200"
        Height="720"
        MinWidth="1160"
        MinHeight="700"
        WindowState="FullScreen"
        SystemDecorations="None"
        Background="{DynamicResource ChromeBrush}"
        Title="MoveMentor Chess">
  <Grid Margin="10" ColumnDefinitions="*,14,620" RowDefinitions="*,Auto">
    <Border Background="{DynamicResource PanelBrush}" CornerRadius="18" Padding="10">
      <Grid RowDefinitions="*,Auto,Auto">
        <Viewbox Stretch="Uniform"
                 StretchDirection="Both"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
          <controls:ChessBoardView x:Name="BoardView"
                                   Width="540"
                                   Height="540"
                                   Fen="{Binding BoardFen}"
                                   RotateBoard="{Binding RotateBoard}"
                                   SelectedSquare="{Binding SelectedSquareName}"
                                   PreviewTargetSquare="{Binding PreviewTargetSquare}"
                                   AvailableMoves="{Binding AvailableMoveSquares}"
                                   Arrows="{Binding BestMoveArrows}"
                                   SquarePressed="BoardView_OnSquarePressed" />
        </Viewbox>

        <StackPanel Grid.Row="1" Margin="10,8,10,0" Spacing="6">
          <TextBlock Foreground="White" FontSize="16" Text="{Binding SuggestionText}" />
          <TextBlock Foreground="White" FontSize="16" Text="{Binding EvaluationText}" />
          <ProgressBar Minimum="0" Maximum="100" Height="18" Value="{Binding EvaluationBarValue}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10,12,10,10" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
          <Button Width="140" Command="{Binding RotateBoardCommand}" Content="ROTATE BOARD" />
          <Button Width="100" Command="{Binding UndoCommand}" Content="UNDO" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Column="2" Background="{DynamicResource PanelBrush}" CornerRadius="18" Padding="10">
      <Grid Margin="10" RowDefinitions="Auto,14,*" ColumnDefinitions="*,*">
        <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
          <Button Grid.Row="0" Grid.Column="0" Height="36" Margin="0,0,6,0" HorizontalAlignment="Stretch" Click="PgnImportButton_Click" Content="PASTE PGN" />
          <Button Grid.Row="0" Grid.Column="1" Height="36" Margin="6,0,0,0" HorizontalAlignment="Stretch" Click="LoadPgnFileButton_Click" Content="LOAD PGN FILE" />

          <Button Grid.Row="1" Grid.Column="0" Height="36" Margin="0,8,6,0" HorizontalAlignment="Stretch" Command="{Binding ApplyNextImportedMoveCommand}" Content="APPLY NEXT" />
          <Button Grid.Row="1" Grid.Column="1" Height="36" Margin="6,8,0,0" HorizontalAlignment="Stretch" Command="{Binding ApplySelectedImportedMoveCommand}" Content="APPLY SELECTED" />

          <Button Grid.Row="2"
                  Grid.Column="0"
                  Height="36"
                  Margin="0,8,6,0"
                  HorizontalAlignment="Stretch"
                  Click="AnalyzeImportedButton_Click"
                  Content="ANALYZE IMPORTED"
                  IsEnabled="{Binding CanOpenImportedAnalysis}" />
          <Button Grid.Row="2" Grid.Column="1" Height="36" Margin="6,8,0,0" HorizontalAlignment="Stretch" Click="ProfilesButton_Click" Content="PROFILES" />

          <Button Grid.Row="3"
                  Grid.Column="0"
                  Height="36"
                  Margin="0,8,6,0"
                  HorizontalAlignment="Stretch"
                  Click="SavedAnalysesButton_Click"
                  Content="SAVED ANALYSES" />
          <Button Grid.Row="3"
                  Grid.Column="1"
                  Height="36"
                  Margin="6,8,0,0"
                  HorizontalAlignment="Stretch"
                  Click="LoadSavedButton_Click"
                  Content="LOAD SAVED" />

          <Button Grid.Row="4"
                  Grid.Column="0"
                  Height="36"
                  Margin="0,8,6,0"
                  HorizontalAlignment="Stretch"
                  Click="OpeningTrainerButton_Click"
                  Content="OPENING TRAINER" />

          <Button Grid.Row="4"
                  Grid.Column="1"
                  Height="36"
                  Margin="6,8,0,0"
                  HorizontalAlignment="Stretch"
                  Click="SettingsButton_Click"
                  Content="SETTINGS" />

          <Button Grid.Row="5"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Height="36"
                  Margin="0,8,0,0"
                  HorizontalAlignment="Stretch"
                  IsEnabled="False"
                  Content="OPENING COVERAGE COMING HERE" />

          <Button Grid.Row="6"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Height="36"
                  Margin="0,8,0,0"
                  HorizontalAlignment="Stretch"
                  Click="CloseButton_Click"
                  Content="CLOSE APP" />
        </Grid>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,*">
          <Grid RowDefinitions="32,*" Margin="0,0,6,0">
            <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="16" Text="{Binding ImportedGameSummary}" />
            <Border Grid.Row="1" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
              <ListBox ItemsSource="{Binding ImportedMoves}"
                       SelectedItem="{Binding SelectedImportedMove}"
                       Background="{DynamicResource ChromeBrush}"
                       Foreground="#D7E2EA"
                       BorderThickness="0">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Foreground" Value="#D7E2EA" />
                    <Setter Property="Background" Value="Transparent" />
                  </Style>
                  <Style Selector="ListBoxItem ContentPresenter">
                    <Setter Property="Foreground" Value="#D7E2EA" />
                  </Style>
                  <Style Selector="ListBoxItem TextBlock">
                    <Setter Property="Foreground" Value="#D7E2EA" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Foreground" Value="#F5FAFD" />
                    <Setter Property="Background" Value="#203746" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="#F5FAFD" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover TextBlock">
                    <Setter Property="Foreground" Value="#F5FAFD" />
                  </Style>
                  <Style Selector="ListBoxItem:selected">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                    <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}" />
                  </Style>
                  <Style Selector="ListBoxItem:selected ContentPresenter">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                  <Style Selector="ListBoxItem:selected TextBlock">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover TextBlock">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ImportedMoveItemViewModel">
                    <Grid Margin="6,3" ColumnDefinitions="Auto,*,58">
                      <Border Grid.Column="0"
                              MinWidth="78"
                              Padding="7,3"
                              CornerRadius="4"
                              Background="{Binding QualityLabelBrush}"
                              IsVisible="{Binding HasAnalysisLabel}">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding QualityLabelForeground}"
                                   Text="{Binding QualityLabel}"
                                   TextTrimming="CharacterEllipsis" />
                      </Border>
                      <TextBlock Grid.Column="1"
                                 Margin="6,0"
                                 VerticalAlignment="Center"
                                 Foreground="#EAF2F7"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 Text="{Binding DisplayText}"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Column="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding EvalDeltaBrush}"
                                 Text="{Binding EvalDeltaText}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>

          <Grid Grid.Column="1" RowDefinitions="32,*" Margin="6,0,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="16" Text="{Binding PieceMoveOptionsHeader}" />
            <Border Grid.Row="1" Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
              <ListBox ItemsSource="{Binding PieceMoveOptions}"
                       SelectedItem="{Binding SelectedPieceMoveOption}"
                       Background="{DynamicResource ChromeBrush}"
                       Foreground="#D7E2EA"
                       BorderThickness="0">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Foreground" Value="#D7E2EA" />
                    <Setter Property="Background" Value="Transparent" />
                  </Style>
                  <Style Selector="ListBoxItem ContentPresenter">
                    <Setter Property="Foreground" Value="#D7E2EA" />
                  </Style>
                  <Style Selector="ListBoxItem TextBlock">
                    <Setter Property="Foreground" Value="#D7E2EA" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Foreground" Value="#F5FAFD" />
                    <Setter Property="Background" Value="#203746" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="#F5FAFD" />
                  </Style>
                  <Style Selector="ListBoxItem:pointerover TextBlock">
                    <Setter Property="Foreground" Value="#F5FAFD" />
                  </Style>
                  <Style Selector="ListBoxItem:selected">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                    <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}" />
                  </Style>
                  <Style Selector="ListBoxItem:selected ContentPresenter">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                  <Style Selector="ListBoxItem:selected TextBlock">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover ContentPresenter">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                  <Style Selector="ListBoxItem:selected:pointerover TextBlock">
                    <Setter Property="Foreground" Value="#FFFFFF" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:PieceMoveOptionViewModel">
                    <Grid Margin="6,2" ColumnDefinitions="*,58">
                      <TextBlock Grid.Column="0"
                                 VerticalAlignment="Center"
                                 Foreground="#EAF2F7"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 Text="{Binding Label}"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Column="1"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 FontFamily="Cascadia Code, Consolas, monospace"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{Binding EvalBrush}"
                                 Text="{Binding EvalText}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.ColumnSpan="3"
            Margin="0,10,0,0"
            Padding="12,8"
            Background="{DynamicResource PanelAccentBrush}"
            CornerRadius="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Foreground="#D7E2EA"
                   FontSize="14"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Text="{Binding StatusMessage}" />
        <Button Width="28"
                Height="28"
                Padding="0"
                Background="#3A171A"
                BorderBrush="#D33838"
                BorderThickness="1"
                CornerRadius="14"
                Command="{Binding StopImportCommand}"
                IsVisible="{Binding IsImportCancellationAvailable}"
                ToolTip.Tip="Stop import">
          <Border Width="10"
                  Height="10"
                  CornerRadius="2"
                  Background="#FF4A4A" />
        </Button>
      </StackPanel>
    </Border>
  </Grid>
</Window>
