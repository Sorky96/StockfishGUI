<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MoveMentorChess.App.Views.SavedAnalysesWindow"
        Width="1220"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowState="FullScreen"
        SystemDecorations="None"
        Title="Saved Analyses"
        Background="{DynamicResource ChromeBrush}">
  <Grid Margin="18" RowDefinitions="Auto,*">
    <Border Padding="16" CornerRadius="18" Background="{DynamicResource PanelBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
        <TextBlock VerticalAlignment="Center"
                   Margin="0,0,16,0"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   Text="Saved Analyses" />
        <TextBox x:Name="FilterTextBox"
                 Grid.Column="1"
                 Background="{DynamicResource ChromeBrush}"
                 Foreground="#EAF2F7"
                 BorderBrush="{DynamicResource PanelAccentBrush}"
                 Watermark="Filter by player, opening, result or labels..."
                 TextChanged="FilterTextBox_OnTextChanged" />
        <Button x:Name="LoadGameButton"
                Grid.Column="2"
                Margin="12,0,0,0"
                IsEnabled="False"
                Click="LoadGameButton_Click"
                Content="Load Game" />
        <Button x:Name="OpenAnalysisButton"
                Grid.Column="3"
                Margin="12,0,0,0"
                IsEnabled="False"
                Click="OpenAnalysisButton_Click"
                Content="Open Analysis" />
        <Button x:Name="DeleteSelectedButton"
                Grid.Column="4"
                Margin="12,0,0,0"
                IsEnabled="False"
                Click="DeleteSelectedButton_Click"
                Content="Delete Selected" />
        <Button Grid.Column="5"
                Margin="12,0,0,0"
                Click="CloseButton_Click"
                Content="Close" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="1.1*,1.4*">
      <Border Padding="12" CornerRadius="18" Background="{DynamicResource PanelBrush}">
        <Grid RowDefinitions="Auto,*">
          <Grid Margin="8,0,8,8" ColumnDefinitions="2.1*,70,92,*,72">
            <TextBlock Foreground="#9EB5C5" FontSize="12" FontWeight="SemiBold" Text="Players" />
            <TextBlock Grid.Column="1" Foreground="#9EB5C5" FontSize="12" FontWeight="SemiBold" Text="Side" />
            <TextBlock Grid.Column="2" Foreground="#9EB5C5" FontSize="12" FontWeight="SemiBold" Text="Date" />
            <TextBlock Grid.Column="3" Foreground="#9EB5C5" FontSize="12" FontWeight="SemiBold" Text="Opening" />
            <TextBlock Grid.Column="4" HorizontalAlignment="Right" Foreground="#9EB5C5" FontSize="12" FontWeight="SemiBold" Text="Marks" />
          </Grid>
        <ListBox x:Name="AnalysesListBox"
                 Grid.Row="1"
                 SelectionChanged="AnalysesListBox_OnSelectionChanged"
                 DoubleTapped="AnalysesListBox_OnDoubleTapped"
                 Background="{DynamicResource ChromeBrush}"
                 Foreground="#D7E2EA"
                 BorderThickness="0">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Foreground" Value="#D7E2EA" />
              <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style Selector="ListBoxItem ContentPresenter">
              <Setter Property="Foreground" Value="#D7E2EA" />
            </Style>
            <Style Selector="ListBoxItem TextBlock">
              <Setter Property="Foreground" Value="#D7E2EA" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Foreground" Value="#F5FAFD" />
              <Setter Property="Background" Value="#203746" />
            </Style>
            <Style Selector="ListBoxItem:pointerover ContentPresenter">
              <Setter Property="Foreground" Value="#F5FAFD" />
            </Style>
            <Style Selector="ListBoxItem:pointerover TextBlock">
              <Setter Property="Foreground" Value="#F5FAFD" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Foreground" Value="#FFFFFF" />
              <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}" />
            </Style>
            <Style Selector="ListBoxItem:selected ContentPresenter">
              <Setter Property="Foreground" Value="#FFFFFF" />
            </Style>
            <Style Selector="ListBoxItem:selected TextBlock">
              <Setter Property="Foreground" Value="#FFFFFF" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:CompileBindings="False">
              <Grid Margin="8,6" ColumnDefinitions="2.1*,70,92,*,72">
                <TextBlock Grid.Column="0"
                           Foreground="#EAF2F7"
                           FontWeight="SemiBold"
                           Text="{Binding Players}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Foreground="#D7E2EA"
                           Text="{Binding Side}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Foreground="#D7E2EA"
                           Text="{Binding Date}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3"
                           Foreground="#D7E2EA"
                           Text="{Binding Opening}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4"
                           HorizontalAlignment="Right"
                           Foreground="#9EB5C5"
                           Text="{Binding Highlights}"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Margin="14,0,0,0"
              Padding="14"
              CornerRadius="18"
              Background="{DynamicResource PanelBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <TextBlock x:Name="DetailsTextBlock"
                     Foreground="White"
                     FontFamily="Cascadia Code, Consolas, monospace"
                     TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
