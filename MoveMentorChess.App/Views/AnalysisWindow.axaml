<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MoveMentorChess.App.Views.AnalysisWindow"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Title="Imported Game Analysis"
        Background="{DynamicResource ChromeBrush}">
  <Grid Margin="18" RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="220,180,*,170,150">
      <ComboBox x:Name="SideComboBox" />
      <ComboBox x:Name="QualityFilterComboBox" Grid.Column="1" Margin="12,0,0,0" />
      <TextBlock x:Name="SummaryTextBlock"
                 Grid.Column="2"
                 Margin="16,0,0,0"
                 VerticalAlignment="Center"
                 Foreground="White"
                 TextWrapping="Wrap" />
      <Button x:Name="AnalyzeButton"
              Grid.Column="3"
              Margin="16,0,0,0"
              Click="AnalyzeButton_Click"
              Content="Run Analysis" />
      <Button x:Name="ShowOnBoardButton"
              Grid.Column="4"
              Margin="12,0,0,0"
              Click="ShowOnBoardButton_Click"
              Content="Show On Board" />
    </Grid>

    <Grid Grid.Row="1" Margin="0,12,0,0" ColumnDefinitions="*,170">
      <StackPanel>
        <TextBlock x:Name="StatusTextBlock"
                   Foreground="#D7E2EA"
                   Text="Choose a side and run the analysis."
                   TextWrapping="Wrap" />
        <TextBlock x:Name="AdviceStatusTextBlock"
                   Margin="0,6,0,0"
                   Foreground="#9EB5C5"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Button x:Name="TestAdviceButton"
              Grid.Column="1"
              HorizontalAlignment="Right"
              Click="TestAdviceButton_Click"
              Content="Test Advice Model" />
    </Grid>

    <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="360,*">
      <Border Background="{DynamicResource ChromeBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1" CornerRadius="8">
        <ListBox x:Name="MistakesListBox"
                 SelectionChanged="MistakesListBox_OnSelectionChanged"
                 DoubleTapped="MistakesListBox_OnDoubleTapped"
                 Background="{DynamicResource ChromeBrush}"
                 Foreground="#D7E2EA"
                 BorderThickness="0">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Foreground" Value="#D7E2EA" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="0" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Foreground" Value="#F5FAFD" />
              <Setter Property="Background" Value="#203746" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Foreground" Value="#FFFFFF" />
              <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:CompileBindings="False">
              <Grid Margin="8,6" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontWeight="SemiBold"
                           Foreground="#EAF2F7"
                           Text="{Binding MoveRange}"
                           TextTrimming="CharacterEllipsis" />
                <Border Grid.Row="0"
                        Grid.Column="1"
                        MinWidth="94"
                        Padding="7,3"
                        CornerRadius="4"
                        Background="{Binding LabelBrush}">
                  <TextBlock HorizontalAlignment="Center"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Foreground="{Binding LabelForeground}"
                             Text="{Binding LabelText}"
                             TextTrimming="CharacterEllipsis" />
                </Border>
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#9EB5C5"
                           Text="{Binding MetaText}"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <Grid Grid.Column="1" Margin="14,0,0,0" RowDefinitions="*,Auto">
        <Border Background="#101820" BorderBrush="#395061" BorderThickness="1" CornerRadius="8" Padding="12">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="DetailsTextBlock"
                       Foreground="White"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       TextWrapping="Wrap" />
          </ScrollViewer>
        </Border>
        <StackPanel Grid.Row="1"
                    Margin="0,10,0,0"
                    Spacing="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="CorrectFeedbackButton"
                    Click="CorrectFeedbackButton_Click"
                    Content="Correct" />
            <Button x:Name="WrongLabelFeedbackButton"
                    Click="WrongLabelFeedbackButton_Click"
                    Content="Wrong label" />
            <Button x:Name="NotUsefulFeedbackButton"
                    Click="NotUsefulFeedbackButton_Click"
                    Content="Not useful" />
            <Button x:Name="TooGenericFeedbackButton"
                    Click="TooGenericFeedbackButton_Click"
                    Content="Too generic" />
            <Button x:Name="GoodExplanationFeedbackButton"
                    Click="GoodExplanationFeedbackButton_Click"
                    Content="Good explanation" />
          </StackPanel>
          <Grid x:Name="ManualCorrectionPanel"
                ColumnDefinitions="180,180,*,110"
                IsVisible="False">
            <ComboBox x:Name="CorrectedLabelComboBox" />
            <TextBox x:Name="CustomLabelTextBox"
                     Grid.Column="1"
                     Margin="8,0,0,0"
                     Background="{DynamicResource ChromeBrush}"
                     Foreground="#EAF2F7"
                     BorderBrush="{DynamicResource PanelAccentBrush}"
                     Watermark="custom label" />
            <TextBox x:Name="FeedbackCommentTextBox"
                     Grid.Column="2"
                     Margin="8,0,0,0"
                     Background="{DynamicResource ChromeBrush}"
                     Foreground="#EAF2F7"
                     BorderBrush="{DynamicResource PanelAccentBrush}"
                     Watermark="comment" />
            <Button x:Name="SaveManualCorrectionButton"
                    Grid.Column="3"
                    Margin="8,0,0,0"
                    Click="SaveManualCorrectionButton_Click"
                    Content="Save" />
          </Grid>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
